---
import { SITE_HANDLE, GITHUB_URL } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<span>&copy; {today.getFullYear()} Koda. All rights reserved.</span>
		<div class="footer-links">
			<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
			<span class="handle">{SITE_HANDLE}</span>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 3em 1em;
		color: var(--muted-dim);
		text-align: center;
		position: relative;
		z-index: 1;
	}
	.footer-inner {
		max-width: 860px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 0.6em;
		align-items: center;
		font-size: 0.85em;
	}
	.footer-links {
		display: flex;
		gap: 1.2em;
		align-items: center;
	}
	footer a {
		color: var(--muted);
	}
	footer a:hover {
		color: var(--fg);
	}
	.handle {
		color: var(--muted-dim);
	}
</style>
