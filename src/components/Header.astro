---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, GITHUB_URL, TIKTOK_URL, YOUTUBE_URL, INSTAGRAM_URL } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href={TIKTOK_URL} target="_blank" rel="noopener">
				<span class="sr-only">Follow on TikTok</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M12.53.02C11.34 0 10.16 0 8.98.01c-.07 1.75.61 3.44 1.87 4.66a5.02 5.02 0 0 0 3.14 1.34V8.7a7.98 7.98 0 0 1-3.15-.77 8.09 8.09 0 0 1-1.28-.78c-.01 2.02.01 4.04-.02 6.05a4.65 4.65 0 0 1-.82 2.31 4.53 4.53 0 0 1-3.65 1.96 4.44 4.44 0 0 1-2.5-.63 4.53 4.53 0 0 1-2.19-3.44c-.01-.3-.02-.6-.01-.89a4.52 4.52 0 0 1 5.24-4.03c.01.93-.02 1.86-.02 2.79a2.07 2.07 0 0 0-2.63 1.29 2.36 2.36 0 0 0-.08.9 2.03 2.03 0 0 0 2.08 1.71 1.99 1.99 0 0 0 1.65-.96c.05-.09.11-.19.11-.3.05-.94.03-1.88.04-2.82.01-2.12-.01-4.24.01-6.35A7.9 7.9 0 0 0 12.53.02z"
					></path></svg
				>
			</a>
			<a href={INSTAGRAM_URL} target="_blank" rel="noopener">
				<span class="sr-only">Follow on Instagram</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M8 1.44c1.87 0 2.1.01 2.83.04.68.03 1.05.15 1.3.24.33.13.56.28.8.52.25.24.4.47.53.8.1.25.21.62.24 1.3.04.73.04.95.04 2.82 0 1.87 0 2.1-.04 2.83-.03.68-.14 1.05-.24 1.3-.13.33-.28.56-.53.8-.24.25-.47.4-.8.53-.25.1-.62.21-1.3.24-.73.04-.95.04-2.83.04-1.87 0-2.1 0-2.82-.04-.68-.03-1.05-.14-1.3-.24a2.16 2.16 0 0 1-.8-.53 2.16 2.16 0 0 1-.53-.8c-.1-.25-.2-.62-.24-1.3-.03-.73-.04-.96-.04-2.83 0-1.87.01-2.09.04-2.82.04-.68.15-1.05.24-1.3.13-.33.28-.56.53-.8.24-.24.47-.4.8-.52.25-.1.62-.21 1.3-.24.72-.04.95-.04 2.82-.04zM8 0C6.1 0 5.86.01 5.12.04c-.74.03-1.24.15-1.68.32-.46.17-.85.4-1.23.79-.39.38-.62.77-.8 1.23-.16.44-.28.94-.32 1.68C1.06 4.8 1.05 5.04 1.05 8s.01 3.2.04 3.94c.04.74.16 1.24.32 1.68.18.46.41.85.8 1.23.38.39.77.62 1.23.8.44.16.94.28 1.68.32.74.03.97.04 4.02.04s3.28-.01 4.02-.04c.74-.04 1.24-.16 1.68-.32.46-.18.85-.41 1.23-.8.39-.38.62-.77.8-1.23.16-.44.28-.94.32-1.68.03-.74.04-.97.04-3.94s-.01-3.2-.04-3.94c-.04-.74-.16-1.24-.32-1.68a3.4 3.4 0 0 0-.8-1.23A3.4 3.4 0 0 0 12.86.36c-.44-.17-.94-.29-1.68-.32C10.44.01 10.2 0 8 0z"
					></path><path
						fill="currentColor"
						d="M8 3.9A4.1 4.1 0 1 0 8 12.1 4.1 4.1 0 0 0 8 3.9zm0 6.77a2.67 2.67 0 1 1 0-5.34 2.67 2.67 0 0 1 0 5.34zM13.28 3.74a.96.96 0 1 1-1.92 0 .96.96 0 0 1 1.92 0z"
					></path></svg
				>
			</a>
			<a href={YOUTUBE_URL} target="_blank" rel="noopener">
				<span class="sr-only">Subscribe on YouTube</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M15.8 4.6a2.02 2.02 0 0 0-1.42-1.43C13.15 3 8 3 8 3s-5.15 0-6.38.17A2.02 2.02 0 0 0 .2 4.6 21.2 21.2 0 0 0 0 8c0 1.14.07 2.29.2 3.4.16.72.73 1.28 1.42 1.43C2.85 13 8 13 8 13s5.15 0 6.38-.17a2.02 2.02 0 0 0 1.42-1.43c.13-1.11.2-2.26.2-3.4a21.2 21.2 0 0 0-.2-3.4zM6.4 10.28V5.72L10.5 8l-4.1 2.28z"
					></path></svg
				>
			</a>
			<a href={GITHUB_URL} target="_blank" rel="noopener">
				<span class="sr-only">View source on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		position: relative;
		z-index: 2;
	}
	h2 {
		margin: 0;
		font-size: 1.05em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--fg);
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 860px;
		margin: 0 auto;
		padding: 1.5em 0;
	}
	nav a {
		padding: 0.4em 0.7em;
		color: var(--muted);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
	}
	nav a:hover {
		color: var(--fg);
	}
	nav a.active {
		color: var(--fg);
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.social-links a {
		color: var(--muted);
		padding: 0.4em;
	}
	.social-links a:hover {
		color: var(--fg);
	}
	@media (max-width: 520px) {
		nav {
			flex-wrap: wrap;
			gap: 0.5em;
		}
	}
</style>
